{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "noEmit": true
  },
  "include": ["vite.config.ts", "capacitor.config.ts", "server/**/*.ts", "src/shared/**/*.ts"]
}
